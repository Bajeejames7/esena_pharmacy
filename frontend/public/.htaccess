# ----------------------------------------------------------------------
# 1. REWRITE ENGINE & ROUTING
# ----------------------------------------------------------------------
Options -MultiViews
RewriteEngine On
RewriteBase /

# Force HTTPS redirect
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://esena.co.ke/$1 [L,R=301]

# A. PHP FILES - Execute directly via Apache
RewriteCond %{REQUEST_URI} \.php$ [NC]
RewriteRule ^ - [L]

# B. STATIC FILES - Serve directly with correct MIME types
# Handle static assets first before any routing rules
RewriteCond %{REQUEST_URI} \.(css|js|json|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp|mp4|pdf|txt|xml)$ [NC]
RewriteRule ^(.*)$ - [L]

# B. API PASSTHROUGH - Handled by Passenger (cPanel Node.js app_uri=api)
# Do NOT proxy /api here - Passenger routes it to the Node.js app automatically
RewriteCond %{REQUEST_URI} ^/api [NC]
RewriteRule ^ - [L]

# C. REACT ROUTER (FRONTEND)
# Handle both main frontend and admin routes - all go to the same index.html
# since this is a single React app with client-side routing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/api [NC]
RewriteCond %{REQUEST_URI} !\.(css|js|json|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp|mp4|pdf|txt|xml)$ [NC]
RewriteRule . /index.html [L]

# ----------------------------------------------------------------------
# 2. MIME TYPE DEFINITIONS
# ----------------------------------------------------------------------
<IfModule mod_mime.c>
    AddType text/css .css
    AddType application/javascript .js
    AddType application/json .json
    AddType image/png .png
    AddType image/jpeg .jpg .jpeg
    AddType image/gif .gif
    AddType image/svg+xml .svg
    AddType image/x-icon .ico
    AddType font/woff .woff
    AddType font/woff2 .woff2
    AddType font/ttf .ttf
    AddType font/eot .eot
    AddType image/webp .webp
</IfModule>

# ----------------------------------------------------------------------
# 3. SECURITY HEADERS & ADVANCED CACHING
# ----------------------------------------------------------------------
Header always set X-Content-Type-Options nosniff
Header always set X-Frame-Options SAMEORIGIN
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Enable GZIP Compression for better performance
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Advanced caching for optimal performance
<IfModule mod_expires.c>
    ExpiresActive On

    # Images - Cache for 1 year with immutable flag
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fonts - Cache for 1 year
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/eot "access plus 1 year"

    # CSS and JavaScript - Cache for 1 month
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"

    # HTML - Short cache for dynamic content
    ExpiresByType text/html "access plus 1 hour"

    # JSON - Cache for 1 day
    ExpiresByType application/json "access plus 1 day"

    # Service Worker - No cache (always fresh)
    <Files "sw.js">
        ExpiresActive Off
        Header unset Cache-Control
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </Files>
</IfModule>

# Cache Control Headers for better performance
<IfModule mod_headers.c>
    # Images - Immutable cache
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Fonts - Immutable cache
    <FilesMatch "\.(woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # CSS and JS - Cache with revalidation
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000, must-revalidate"
    </FilesMatch>

    # HTML - Short cache
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>

    # Service Worker - No cache
    <Files "sw.js">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </Files>
</IfModule>

# Enable ETags for better caching validation
FileETag MTime Size
